# Anthropic (Claude) — optional; prototype runs without these until integration ships.
# Copy to .env.local and set ANTHROPIC_API_KEY for local experiments (never commit .env.local).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Deployed eval viewer (/internal/eval) — server-side password gate for published sanitized data in production.
# In local dev, /internal/eval reads gitignored eval files and does not require a password.
# Never commit real passwords.
EVAL_VIEWER_PASSWORD=
