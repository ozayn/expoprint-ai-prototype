  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "cheerio": "^1.2.0",
    "fabric": "^7.3.1",
    "next": "^16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "overrides": {
    "postcss": "8.5.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "20.19.41",
    "@types/react": "19.2.15",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "5.9.3"
  }
