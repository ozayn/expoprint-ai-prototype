# Anthropic (Claude) — optional; prototype runs without these until integration ships.
# Copy to .env.local and set ANTHROPIC_API_KEY for local experiments (never commit .env.local).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Internal historical eval viewer (/internal/eval) — password for deployed sample-data UI.
# Never commit real passwords. Not used by /dev/eval (local file viewer).
INTERNAL_EVAL_PASSWORD=
