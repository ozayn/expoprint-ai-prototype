    "lint": "eslint",
    "api:test": "bash scripts/test-design-intake-api.sh",
    "api:compare": "bash scripts/compare-analyze-api-routes.sh",
    "api:evaluate": "node scripts/evaluate-design-intake-api.mjs",
    "api:logo-debug": "node scripts/debug-logo-candidates.mjs",
    "eval:historical": "tsx scripts/eval/runHistoricalExtractionEval.ts --dry-run",
    "eval:urls": "tsx scripts/eval/extractHistoricalUrlCandidates.ts",
    "eval:urls:test": "tsx scripts/eval/lib/urlCandidates.test.ts",
    "eval:url-dedup:test": "tsx scripts/eval/lib/evalUrlDedup.test.ts",
    "eval:canonical-dedup:test": "tsx scripts/eval/lib/evalCanonicalDedup.test.ts",
    "eval:select-urls:test": "tsx scripts/eval/lib/selectUrlCandidates.test.ts",
    "eval:url-priority:test": "tsx src/lib/evalLocal/evalUrlPriority.test.ts",
    "eval:extract": "tsx scripts/eval/runHistoricalWebsiteExtraction.ts",
    "eval:extract-and-review": "tsx scripts/eval/extractAndReview.ts",
    "eval:extract-and-review:test": "tsx scripts/eval/lib/extractAndReview.test.ts",
    "eval:combine-reviews": "tsx scripts/eval/combineReviewQueues.ts",
