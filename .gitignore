# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit API keys or local secrets
.env
.env.local
.env.*.local
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Historical eval — partner data and outputs stay local (never push to GitHub)
data/private/
data/private/**

data/eval/runs/**
!data/eval/runs/.gitkeep
data/eval/results/**
!data/eval/results/.gitkeep

# Eval artifact filename patterns (any folder under data/)
data/**/url_candidates_*.csv
data/**/extraction_summary_*.csv
data/**/extraction_run_*.jsonl
data/**/run_*.jsonl
data/**/results_*.csv
**/*basic_design_service_query*.csv

*.local.csv

# Other eval CSVs except the tracked fake example
data/eval/*.csv
!data/eval/metabase_sample.example.csv
